{
  "name": "laba3",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "bdd": "cucumber-js --format summary --format html:report.html",
    "test:unit": "jest --config=jest.config.allure.js",
    "test:api": "cucumber-js --format json:allure-results/cucumber.json",
    "test:ui:raw": "npx playwright test --reporter=line,allure-playwright",
    "test:ui": "start-server-and-test start http://localhost:3000 \"npm run test:ui:raw\"",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "start": "node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-jest": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "start-server-and-test": "^3.0.2",
    "supertest": "^7.2.2",
    "wait-on": "^9.0.5"
  }
}
